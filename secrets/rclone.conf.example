# rclone config for bulk capture ingestion (drive_ingestor.py).
# Copy to ./secrets/rclone.conf (gitignored) and fill in your remote.
# Mounted read-only into the container at /run/secrets/rclone_conf; the
# RCLONE_CONFIG env var points the worker at it.
#
# The service account needs WRITE scope on the capture folder so the worker can
# push outputs back to <session>/outputs/ (see video-ingestion-plan §8).
# Place the service-account JSON alongside this file and reference it by the
# in-container path. Add a second secret mount for the JSON if you prefer it
# separate from the rclone config.

# --- Google Drive remote (folders of MP4s shared with the service account) ---
[captures]
type = drive
scope = drive
service_account_file = /run/secrets/gdrive_sa.json
# root_folder_id is the Drive folder ID that holds one sub-folder per capture.
root_folder_id = REPLACE_WITH_SHARED_FOLDER_ID

# --- Or a Google Cloud Storage remote ---
# [captures]
# type = google cloud storage
# service_account_file = /run/secrets/gdrive_sa.json
# project_number = REPLACE_WITH_GCP_PROJECT_NUMBER
# bucket_policy_only = true
#
# Then set DRIVE_INGEST_REMOTE=captures:<bucket>/captures (GCS)
# or            DRIVE_INGEST_REMOTE=captures: (Drive, root_folder_id already set)
