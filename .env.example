# =============================================================================
# Gaussian Toolkit — environment template
# =============================================================================
# Copy to .env and fill in. `.env` is gitignored; this template is committed.
#   cp .env.example .env
# docker-compose.consolidated.yml loads .env via `env_file:` (so these are both
# interpolated into the compose file AND injected into the main container).
# Only HF_TOKEN is strictly required for a basic run; everything else has a
# working default and is opt-in.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Credentials (required / recommended)
# -----------------------------------------------------------------------------
# HuggingFace token — required for SAM3 segmentation model downloads.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key — for the in-container Claude Code orchestrator. Optional;
# leave blank if you drive the pipeline via CLI/web only. (The web UI can also
# store this at LFS_API_KEY_PATH instead.)
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# 2. Bulk capture ingestion — drive_ingestor.py (Google Cloud / Drive)
# -----------------------------------------------------------------------------
# rclone remote + base path. Each sub-folder under it = one capture session;
# the MP4s inside a session folder = its "sets". Leave BLANK to disable the
# ingestor entirely (the worker only runs when this is set).
#   examples:  gcs:my-bucket/captures   |   gdrive:Captures
DRIVE_INGEST_REMOTE=

# Host path to the rclone config holding your service-account-authenticated
# remote. Defaults to the committed placeholder so `docker compose up` works
# WITHOUT Drive creds. When ready to ingest, create ./secrets/rclone.conf
# (gitignored) from ./secrets/rclone.conf.example and point this at it.
# The service account needs WRITE scope (outputs push back to <session>/outputs/).
RCLONE_CONF_FILE=./secrets/rclone.conf.example

# Host NVMe paths bind-mounted to /data/raw and /data/scratch. The active
# session's raw videos land in raw; frames/COLMAP/model in scratch; both are
# purged after a verified upload. Point at a large NVMe (250–500 GB — plan §4).
DRIVE_RAW_HOST_DIR=./data/raw
DRIVE_SCRATCH_HOST_DIR=./data/scratch

# -----------------------------------------------------------------------------
# 3. Mesh-backend build gates (BUILD-TIME — change requires `docker compose build`)
# -----------------------------------------------------------------------------
# CoMe sidecar (confidence-based, ~3x faster than MILo). 0 = skip building it.
#   LICENSING: CoMe ships the Inria/MPII Gaussian-Splatting licence — NON-
#   COMMERCIAL research only. Set to 1 only for research/evaluation use.
INSTALL_COME=0

# GaussianWrapping (thin-structure meshes) inside the milo sidecar. 0 = skip.
#   No formal LICENSE in the repo — dev/research only. See ADR-005.
INSTALL_GAUSSIANWRAPPING=0

# -----------------------------------------------------------------------------
# 4. Optional runtime tuning (have sensible defaults — override only if needed)
# -----------------------------------------------------------------------------
# Auto mesh-backend (config mesh_method="auto"): hint that the scene has thin
# structures (wires/fences/railings) -> prefer GaussianWrapping. 1 to enable.
LICHTFELD_THIN_STRUCTURE=0

# Suppress the CoMe non-commercial-licence WARNING in dev/CI. 1 to suppress.
COME_DEV_ENVIRONMENT=0

# Web UI (Flask) — port and debug. Defaults shown.
LFS_WEB_PORT=7860
LFS_DEBUG=0

# In-container data dirs (defaults match the compose mounts; rarely changed).
# LFS_INPUT_DIR=/data/input
# LFS_OUTPUT_DIR=/data/output
# LFS_JOBS_DIR=/data/jobs
# LFS_API_KEY_PATH=/data/.anthropic_key
# DRIVE_RAW_DIR=/data/raw
# DRIVE_SCRATCH_DIR=/data/scratch

# Sidecar install dirs / conda envs (defaults match the Dockerfiles; rarely changed).
# MILO_DIR=/opt/milo            MILO_CONDA_ENV=milo
# COME_DIR=/opt/come            COME_CONDA_ENV=come
# GW_DIR=/opt/gaussianwrapping  GW_CONDA_ENV=milo

# NOTE: RCLONE_CONFIG is set by compose to /run/secrets/rclone_conf — do NOT set
# it here. Put the actual remote + service_account_file in ./secrets/rclone.conf.
