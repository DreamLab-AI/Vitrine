        E --> F{Strategy Selection}
        F -->|Default| G[MRNF 30K iterations]
        F -->|Adaptive| H[MCMC 15K iterations]
        F -->|High Quality| I[MILo 18K iterations]
        G --> J[Trained Gaussians]
        H --> J
        I --> J
    end

    subgraph Extraction["Mesh & Export"]
        J --> K{Mesh Method}
        K -->|Fast| L[TSDF Fusion]
        K -->|Balanced| M[SuGaR]
        K -->|Quality| N[MILo Mesh]
        L --> O[Triangle Mesh]
        M --> O
        N --> O
    end

    subgraph Output["Output Stage"]
        O --> P[Blender Import]
        P --> Q[Material Assignment]
        Q --> R[USD Export]
        R --> S[Web Viewer]
        R --> T[AR/VR Delivery]
    end

